{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "SSHagement",
  "version": "1.0.0",
  "identifier": "com.sshagement.app",
  "build": {
    "beforeDevCommand": "npm run dev",
    "devUrl": "http://localhost:1420",
    "beforeBuildCommand": "npm run build",
    "frontendDist": "../build"
  },
  "app": {
    "windows": [
      {
        "title": "SSHagement",
        "width": 1200,
        "height": 760,
        "minWidth": 880,
        "minHeight": 560,
        "decorations": false,
        "transparent": false,
        "theme": "Dark",
        "center": true,
        "backgroundColor": "#0b0d10",
        "dragDropEnabled": false
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": ["nsis"],
    "publisher": "tglagcs",
    "copyright": "© 2026 tglagcs",
    "homepage": "https://github.com/tglagcs/SSHagement",
    "category": "DeveloperTool",
    "shortDescription": "Offline-first SSH client for Windows",
    "longDescription": "SSHagement — an offline-first, no-cloud, no-telemetry SSH client for Windows. A minimalist-but-premium Termius alternative with tabs, split panes, multi-window, snippets and folders.",
    "licenseFile": "../LICENSE",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/smooth_icon.ico"
    ],
    "windows": {
      "nsis": {
        "installMode": "currentUser"
      }
    }
  }
}
